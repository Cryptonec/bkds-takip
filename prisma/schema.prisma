generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  superadmin
  admin
  yonetici
  danisma
}

enum AttendanceStatus {
  bekleniyor
  gecikiyor
  giris_eksik
  kritik
  gec_geldi
  giris_tamam
  cikis_eksik
  tamamlandi
  bkds_muaf
  erken_cikis
  derste
}

enum StaffAttendanceStatus {
  bekleniyor
  derste
  gelmedi
  gec_basladi
  gecikiyor
}

enum AlertSeverity {
  normal
  uyari
  kritik
}

enum ImportStatus {
  bekliyor
  isleniyor
  tamamlandi
  hata
}

enum SubscriptionPlan {
  trial
  basic
  pro
}

// ─── Multi-tenant modeller ───────────────────────────────────────────────────

model Organization {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique  // Rehapp org_slug ile eşleşmeli
  active      Boolean          @default(true)
  plan        SubscriptionPlan @default(trial)
  trialEndsAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  users        User[]
  credentials  BkdsCredential[]
  ssoTokens    SsoToken[]
  students     Student[]
  staff        Staff[]
  lessonSessions LessonSession[]
  staffSessions  StaffSession[]
  bkdsRaw      BkdsRaw[]
  bkdsAggregates BkdsAggregate[]
  attendances  Attendance[]
  staffAttendances StaffAttendance[]
  importJobs   ImportJob[]
  alerts       Alert[]
  bkdsPersonelLogs BkdsPersonelLog[]
  systemSettings   SystemSetting[]
  actionLogs   ActionLog[]
}

model BkdsCredential {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String       @unique
  username       String
  password       String       // encrypt edilmeli prod'da
  cityId         String    @default("")
  districtId     String    @default("")
  remId          String    @default("")
  apiUrl         String       @default("https://bkds.meb.gov.tr")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model SsoToken {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  token          String       @unique
  role           Role         @default(admin)
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime     @default(now())

  @@index([token])
  @@index([organizationId])
}

// ─── Kullanıcı ───────────────────────────────────────────────────────────────

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  name           String
  password       String
  role           Role         @default(danisma)
  active         Boolean      @default(true)
  organization   Organization? @relation(fields: [organizationId], references: [id])
  organizationId String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  actionLogs ActionLog[]
}

// ─── Öğrenci & Personel ──────────────────────────────────────────────────────

model Student {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  adSoyad        String
  ogrenciNo      String?
  tc             String?
  normalizedName String
  aktif          Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  lessonSessions LessonSession[]
  attendances    Attendance[]
  bkdsAggregates BkdsAggregate[]

  @@unique([ogrenciNo, organizationId])
  @@index([organizationId])
}

model Staff {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  adSoyad        String
  normalizedName String
  aktif          Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  lessonSessions   LessonSession[]
  staffSessions    StaffSession[]
  staffAttendances StaffAttendance[]
  bkdsLogs         BkdsPersonelLog[]

  @@index([organizationId])
}

model LessonSession {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  student        Student      @relation(fields: [studentId], references: [id])
  studentId      String
  staff          Staff        @relation(fields: [staffId], references: [id])
  staffId        String
  tarih          DateTime     @db.Date
  baslangic      DateTime
  bitis          DateTime
  derslik        String
  bkdsRequired   Boolean      @default(true)
  importJobId    String?
  createdAt      DateTime     @default(now())

  attendance   Attendance?
  importJob    ImportJob?   @relation(fields: [importJobId], references: [id])

  @@index([tarih])
  @@index([studentId, tarih])
  @@index([organizationId, tarih])
}

model StaffSession {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  staff          Staff        @relation(fields: [staffId], references: [id])
  staffId        String
  tarih          DateTime     @db.Date
  baslangic      DateTime
  bitis          DateTime
  derslik        String
  basladiMi      Boolean      @default(false)
  baslamaZamani  DateTime?
  sonCikisZamani DateTime?
  createdAt      DateTime     @default(now())

  staffAttendance StaffAttendance?

  @@index([tarih])
  @@index([staffId, tarih])
  @@index([organizationId, tarih])
}

model BkdsRaw {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  tarih          DateTime     @db.Date
  adSoyad        String
  maskedTc       String?
  girisZamani    DateTime
  cikisZamani    DateTime?
  fetchedAt      DateTime     @default(now())

  @@index([tarih])
  @@index([adSoyad, tarih])
  @@index([organizationId, tarih])
}

model BkdsAggregate {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  student        Student?     @relation(fields: [studentId], references: [id])
  studentId      String?
  tarih          DateTime     @db.Date
  adSoyad        String
  ilkGiris       DateTime
  sonCikis       DateTime?
  fetchedAt      DateTime     @default(now())

  @@unique([studentId, tarih, organizationId])
  @@index([tarih])
  @@index([organizationId, tarih])
}

model Attendance {
  id              String           @id @default(cuid())
  organization    Organization     @relation(fields: [organizationId], references: [id])
  organizationId  String
  lessonSession   LessonSession    @relation(fields: [lessonSessionId], references: [id])
  lessonSessionId String           @unique
  student         Student          @relation(fields: [studentId], references: [id])
  studentId       String
  tarih           DateTime         @db.Date
  status          AttendanceStatus @default(bekleniyor)
  girisZamani     DateTime?
  cikisZamani     DateTime?
  gercekGiris     DateTime?
  gercekCikis     DateTime?
  updatedAt       DateTime         @updatedAt

  @@index([tarih])
  @@index([studentId, tarih])
  @@index([organizationId, tarih])
}

model StaffAttendance {
  id             String                @id @default(cuid())
  organization   Organization          @relation(fields: [organizationId], references: [id])
  organizationId String
  staffSession   StaffSession          @relation(fields: [staffSessionId], references: [id])
  staffSessionId String                @unique
  staff          Staff                 @relation(fields: [staffId], references: [id])
  staffId        String
  tarih          DateTime              @db.Date
  status         StaffAttendanceStatus @default(bekleniyor)
  updatedAt      DateTime              @updatedAt

  @@index([tarih])
  @@index([organizationId, tarih])
}

model ImportJob {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  fileName       String
  status         ImportStatus @default(bekliyor)
  totalRows      Int          @default(0)
  processedRows  Int          @default(0)
  errorRows      Int          @default(0)
  errorDetails   Json?
  createdAt      DateTime     @default(now())
  completedAt    DateTime?

  lessonSessions LessonSession[]

  @@index([organizationId])
}

model SystemSetting {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  key            String
  value          String
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, key])
}

model ActionLog {
  id             String       @id @default(cuid())
  organization   Organization? @relation(fields: [organizationId], references: [id])
  organizationId String?
  user           User?        @relation(fields: [userId], references: [id])
  userId         String?
  action         String
  entity         String?
  entityId       String?
  details        Json?
  createdAt      DateTime     @default(now())

  @@index([createdAt])
  @@index([organizationId])
}

model Alert {
  id             String        @id @default(cuid())
  organization   Organization  @relation(fields: [organizationId], references: [id])
  organizationId String
  type           String
  severity       AlertSeverity
  entityType     String
  entityId       String
  message        String
  tarih          DateTime      @db.Date
  resolved       Boolean       @default(false)
  resolvedAt     DateTime?
  createdAt      DateTime      @default(now())

  @@index([tarih, resolved])
  @@index([organizationId, tarih])
}

model BkdsPersonelLog {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  tarih          DateTime     @db.Date
  maskedAd       String
  ilkGiris       DateTime
  sonCikis       DateTime?
  staffId        String?
  staff          Staff?       @relation(fields: [staffId], references: [id])
  eslesmeDurumu  String
  tahminEdilenAd String?
  createdAt      DateTime     @default(now())

  @@index([tarih])
  @@index([staffId, tarih])
  @@index([organizationId, tarih])
}
