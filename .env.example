# ─── Veritabanı ──────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/bkds_takip"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL="https://bkds.rehapp.com"
NEXTAUTH_SECRET="openssl-rand-hex-32-ile-uret"

# ─── SSO (Rehapp ↔ bkds-takip entegrasyonu) ──────────────────────────────────
# Rehapp FastAPI ve bkds-takip arasında paylaşılan gizli anahtar.
# Her iki uygulamada da aynı değer olmalı.
# Üretim: openssl rand -hex 32
SSO_SECRET="paylasilmis-gizli-anahtar-buraya"

# ─── Varsayılan BKDS Kimlik Bilgileri (tek kurum / geliştirme modu) ───────────
# Çok kiracılı (SaaS) modda bu değerler DB'deki BkdsCredential tablosundan okunur.
# Bu değerler sadece DB kaydı yoksa fallback olarak kullanılır.
BKDS_API_URL="https://bkds-api.meb.gov.tr"
BKDS_USERNAME="kurum_kullanici_adi"
BKDS_PASSWORD="kurum_sifresi"
BKDS_CITY_ID=""
BKDS_DISTRICT_ID=""
BKDS_REM_ID=""

# Polling aralığı (ms) — varsayılan 60 saniye
BKDS_POLL_INTERVAL="60000"
