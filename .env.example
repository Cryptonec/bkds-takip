# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  BKDS Takip — Ortam Değişkenleri Şablonu
#  kurulum.bat veya kurulum.sh otomatik doldurur.
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Veritabanı şifresi (docker-compose otomatik kullanır)
DB_PASSWORD=guclu_bir_sifre_girin

# Uygulama URL — değiştirmeyin
NEXTAUTH_URL=http://localhost:3000

# Güvenlik anahtarı (otomatik üretilir)
NEXTAUTH_SECRET=

# Kurulum API güvenlik anahtarı (otomatik üretilir)
SSO_SECRET=

# BKDS yoklama sıklığı (ms) — varsayılan 10 saniye
BKDS_POLL_INTERVAL=10000
